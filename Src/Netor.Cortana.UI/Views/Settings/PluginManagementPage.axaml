<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Netor.Cortana.UI.Views.Settings.PluginManagementPage"
             x:CompileBindings="True">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="16,12,16,8">
            <TextBlock Text="插件管理" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="管理本地插件、全局插件，以及插件和智能体绑定"
                       Foreground="{StaticResource SubtextBrush}" FontSize="12" />
        </StackPanel>

        <Grid RowDefinitions="Auto,*" Margin="16,0,16,12">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,10">
                <TextBox x:Name="TxtSearch" Grid.Column="0" Classes="form-input"
                         PlaceholderText="搜索插件名称、ID 或简介"
                         TextChanged="OnSearchTextChanged" />
                <Button Grid.Column="1" Classes="btn-secondary" Content="刷新" Click="OnRefreshClick" />
                <Button Grid.Column="2" Classes="btn-secondary" Content="打开目录" Click="OnOpenGlobalDirectoryClick" />
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="12">
                <Border Grid.Column="0" Background="{StaticResource MantleBrush}"
                        BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1"
                        CornerRadius="4" Padding="8">
                    <DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PluginListPanel" Spacing="6" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource Surface0Brush}"
                        BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1"
                        CornerRadius="4" Padding="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,24,0">
                        <StackPanel x:Name="DetailPanel" Spacing="12" >
                            <TextBlock Text="请选择一个插件"
                                       Foreground="{StaticResource SubtextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

</UserControl>
