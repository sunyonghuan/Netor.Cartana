<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Netor.Cortana.AvaloniaUI.Views.Settings.ToolManagementPage"
             x:CompileBindings="True">

    <DockPanel>
        <!-- 顶部标题栏 -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="16,12,16,8">
            <TextBlock Text="工具管理" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="为智能体启用/禁用插件工具和 MCP 服务器工具"
                       Foreground="{StaticResource SubtextBrush}" FontSize="12" />
        </StackPanel>

        <!-- 智能体选择器 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="16,0,16,8">
            <TextBlock Text="选择智能体：" Foreground="{StaticResource TextBrush}" FontSize="13"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="CboAgent" Classes="form-combo" MinWidth="180"
                      SelectionChanged="OnAgentChanged">
                <ComboBoxItem Content="— 请选择 —" Tag="" />
            </ComboBox>
        </StackPanel>

        <!-- 保存按钮 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="16,8,16,8">
            <Button x:Name="BtnSave" Classes="btn-primary" Content="保存工具配置"
                    Click="OnSaveClick" IsVisible="False" />
        </StackPanel>

        <!-- 工具列表 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ToolsContainer" Spacing="12" Margin="8,0" />
        </ScrollViewer>
    </DockPanel>

</UserControl>
