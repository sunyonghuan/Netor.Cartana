<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Netor.Cortana.AvaloniaUI.Views.Settings.SystemSettingsPage"
             x:CompileBindings="True">

    <DockPanel>
        <!-- 顶部标题栏 -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="16,12,16,8">
            <TextBlock Text="系统设置" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Classes="btn-secondary" Content="恢复默认" Click="OnResetClick" />
                <Button Classes="btn-primary" Content="保存设置" Click="OnSaveClick" />
            </StackPanel>
        </Grid>

        <!-- 设置项容器 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SettingsContainer" Spacing="12" Margin="8,0" />
        </ScrollViewer>
    </DockPanel>

</UserControl>
