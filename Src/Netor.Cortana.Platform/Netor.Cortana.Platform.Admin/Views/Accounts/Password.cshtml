@model Netor.Cortana.Platform.Admin.Models.Accounts.AccountPasswordViewModel
@{
    ViewData["Title"] = "重置用户密码";
}

<section class="admin-card admin-form-card">
    <div class="admin-card-header">
        <div>
            <h2 class="admin-card-title">重置用户密码</h2>
            <div class="text-secondary">@Model.LoginUserName</div>
        </div>
        <a class="layui-btn layui-btn-primary layui-btn-sm" asp-action="Details" asp-route-id="@Model.Id">返回详情</a>
    </div>
    <div class="admin-card-body">
        <form method="post" class="admin-edit-form layui-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="LoginUserName" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control layui-input" type="password" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="NewSafePassword" class="form-label"></label>
                    <input asp-for="NewSafePassword" class="form-control layui-input" type="password" autocomplete="new-password" placeholder="留空则不修改" />
                    <span asp-validation-for="NewSafePassword" class="text-danger"></span>
                </div>
            </div>
            <div class="layui-elem-quote layui-quote-nm mt-4 mb-0">提交后会立即覆盖用户密码，请确认已经完成身份核验。</div>
            <div class="admin-form-actions">
                <button class="layui-btn layui-btn-danger" type="submit">确认重置</button>
                <a class="layui-btn layui-btn-primary" asp-action="Details" asp-route-id="@Model.Id">取消</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
