@model Netor.Cortana.Platform.Admin.Models.Orders.OrderDetailViewModel
@{
    ViewData["Title"] = "订单详情";
}

<section class="admin-card mb-4">
    <div class="admin-card-header">
        <div>
            <h2 class="admin-card-title">@Model.Title</h2>
            <div class="text-secondary">@Model.No</div>
        </div>
        <a class="layui-btn layui-btn-primary layui-btn-sm" asp-action="Index">返回订单</a>
    </div>
    <div class="admin-card-body">
        <div class="asset-detail-grid">
            <div>
                <div class="detail-label">用户</div>
                <strong>@Model.AccountName</strong>
            </div>
            <div>
                <div class="detail-label">资源</div>
                <strong>@Model.AssetName</strong>
            </div>
            <div>
                <div class="detail-label">定价方案</div>
                <strong>@Model.PricingPlanName</strong>
            </div>
            <div>
                <div class="detail-label">订单金额</div>
                <strong>@Model.Money.ToString("0.00")</strong>
            </div>
            <div>
                <div class="detail-label">购买数量</div>
                <strong>@Model.Numbers</strong>
            </div>
            <div>
                <div class="detail-label">支付时间</div>
                <strong>@(Model.PayTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</strong>
            </div>
            <div>
                <div class="detail-label">支付状态</div>
                <span class="admin-badge @GetPayBadgeClass(Model.PayStatus)">@GetPayStatusName(Model.PayStatus)</span>
            </div>
            <div>
                <div class="detail-label">订单状态</div>
                <span class="admin-badge @GetStatusBadgeClass(Model.Status)">@GetOrderStatusName(Model.Status)</span>
            </div>
            <div>
                <div class="detail-label">支付方式</div>
                <strong>@GetPayMethodName(Model.PayMethod)</strong>
            </div>
        </div>

        <hr />

        <h3 class="h5">订单内容</h3>
        <p class="text-secondary mb-0">@(string.IsNullOrWhiteSpace(Model.Content) ? "-" : Model.Content)</p>
    </div>
</section>

<section class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title">交易流水</h2>
        <span class="text-secondary">共 @Model.Transactions.Count 条</span>
    </div>
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table layui-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>流水</th>
                        <th>三方单号</th>
                        <th>金额</th>
                        <th>实际金额</th>
                        <th>支付</th>
                        <th>支付时间</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-secondary py-5">暂无交易流水。</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Transactions)
                        {
                            <tr>
                                <td>
                                    <strong>@item.No</strong>
                                    <small class="d-block text-secondary">@item.Title</small>
                                </td>
                                <td>@item.ThirdNo</td>
                                <td>@item.Money.ToString("0.00")</td>
                                <td>@item.RealMoney.ToString("0.00")</td>
                                <td><span class="admin-badge @GetPayBadgeClass(item.PayStatus)">@GetPayStatusName(item.PayStatus)</span></td>
                                <td>@(item.PayTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@functions {
    private static string GetPayStatusName(byte status) => status switch
    {
        1 => "待支付",
        2 => "已支付",
        3 => "已取消",
        4 => "支付失败",
        _ => $"状态 {status}"
    };

    private static string GetOrderStatusName(byte status) => status switch
    {
        1 => "待处理",
        2 => "已完成",
        3 => "已取消",
        4 => "已失败",
        _ => $"状态 {status}"
    };

    private static string GetPayMethodName(byte method) => method switch
    {
        1 => "余额",
        2 => "微信",
        3 => "支付宝",
        4 => "银行卡",
        _ => method == 0 ? "未指定" : $"方式 {method}"
    };

    private static string GetPayBadgeClass(byte status) => status switch
    {
        2 => "admin-badge-success",
        3 => "admin-badge-muted",
        4 => "admin-badge-danger",
        _ => "admin-badge-warning"
    };

    private static string GetStatusBadgeClass(byte status) => status switch
    {
        2 => "admin-badge-success",
        3 => "admin-badge-muted",
        4 => "admin-badge-danger",
        _ => "admin-badge-warning"
    };
}
