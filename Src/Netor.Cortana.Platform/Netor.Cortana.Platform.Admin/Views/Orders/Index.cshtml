@model Netor.Cortana.Platform.Admin.Models.Orders.OrderIndexViewModel
@{
    ViewData["Title"] = "订单交易";
}

<section class="metric-grid mb-4">
    <article class="admin-card metric-card">
        <div class="metric-icon">￥</div>
        <strong>@Model.TotalCount</strong>
        <span>订单总数</span>
        <p>当前筛选范围订单记录</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">●</div>
        <strong>@Model.PaidCount</strong>
        <span>已支付订单</span>
        <p>完成支付的销售单</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">◌</div>
        <strong>@Model.PendingCount</strong>
        <span>待支付订单</span>
        <p>等待用户完成支付</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">⇄</div>
        <strong>@Model.PaidAmount.ToString("0.00")</strong>
        <span>支付金额</span>
        <p><a asp-action="Transactions">查看交易流水</a></p>
    </article>
</section>

<section class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title">订单列表</h2>
        <span class="text-secondary">第 @Model.Page / @Model.TotalPages 页</span>
    </div>
    <div class="admin-card-body border-bottom">
        <form method="get" class="admin-filter-form admin-filter-form-compact layui-form">
            <div>
                <label class="form-label" for="keyword">关键词</label>
                <input id="keyword" class="form-control layui-input" name="keyword" value="@Model.Keyword" placeholder="单号 / 用户 / 标题 / 内容" />
            </div>
            <div>
                <label class="form-label" for="status">订单状态</label>
                <select id="status" class="form-select layui-select" name="status">
                    <option value="">全部状态</option>
                    @foreach (var option in GetStatusOptions())
                    {
                        <option value="@option.Value" selected="@(Model.Status == option.Value)">@option.Text</option>
                    }
                </select>
            </div>
            <div class="admin-filter-actions">
                <button class="layui-btn layui-btn-normal" type="submit">筛选</button>
                <a class="layui-btn layui-btn-primary" asp-action="Index">重置</a>
            </div>
        </form>
    </div>
    <form id="orderBatchForm" asp-action="BatchOrders" method="post" class="admin-batchbar">
        @Html.AntiForgeryToken()
        <strong>批量操作</strong>
        <div class="admin-batchbar-fields">
            <select class="form-select layui-select" name="status" aria-label="批量订单状态">
                @foreach (var option in GetStatusOptions())
                {
                    <option value="@option.Value">批量设为 @option.Text</option>
                }
            </select>
            <button class="layui-btn layui-btn-normal" type="submit">应用</button>
        </div>
    </form>
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table layui-table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="admin-check-cell"><input class="form-check-input" type="checkbox" data-check-all="orders" aria-label="全选订单" /></th>
                        <th>订单</th>
                        <th>用户</th>
                        <th>资源</th>
                        <th>金额</th>
                        <th>支付</th>
                        <th>状态</th>
                        <th>流水</th>
                        <th class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-secondary py-5">暂无订单记录。</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="admin-check-cell"><input class="form-check-input" form="orderBatchForm" type="checkbox" name="ids" value="@item.Id" data-check-item="orders" aria-label="选择订单 @item.No" /></td>
                                <td>
                                    <strong>@item.Title</strong>
                                    <small class="d-block text-secondary">@item.No</small>
                                </td>
                                <td>@item.AccountName</td>
                                <td>
                                    <span>@item.AssetName</span>
                                    <small class="d-block text-secondary">@item.PricingPlanName</small>
                                </td>
                                <td>
                                    <strong>@item.Money.ToString("0.00")</strong>
                                    <small class="d-block text-secondary">数量 @item.Numbers</small>
                                </td>
                                <td><span class="admin-badge @GetPayBadgeClass(item.PayStatus)">@GetPayStatusName(item.PayStatus)</span></td>
                                <td><span class="admin-badge @GetStatusBadgeClass(item.Status)">@GetOrderStatusName(item.Status)</span></td>
                                <td>@item.TransactionCount</td>
                                <td class="text-end">
                                    <div class="layui-btn-group admin-row-actions">
                                        <a class="layui-btn layui-btn-primary layui-btn-sm" asp-action="Details" asp-route-id="@item.Id">详情</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="admin-card-body admin-pager">
        <div class="text-secondary">共 @Model.TotalCount 条，每页 @Model.PageSize 条</div>
        <div class="layui-btn-group">
            <a class="layui-btn layui-btn-primary @(Model.HasPreviousPage ? string.Empty : "layui-btn-disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">上一页</a>
            <a class="layui-btn layui-btn-primary @(Model.HasNextPage ? string.Empty : "layui-btn-disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">下一页</a>
        </div>
    </div>
</section>

@functions {
    private static IEnumerable<(byte Value, string Text)> GetStatusOptions()
    {
        return [(1, "待处理"), (2, "已完成"), (3, "已取消"), (4, "已失败")];
    }

    private static string GetPayStatusName(byte status) => status switch
    {
        1 => "待支付",
        2 => "已支付",
        3 => "已取消",
        4 => "支付失败",
        _ => $"状态 {status}"
    };

    private static string GetOrderStatusName(byte status) => status switch
    {
        1 => "待处理",
        2 => "已完成",
        3 => "已取消",
        4 => "已失败",
        _ => $"状态 {status}"
    };

    private static string GetPayBadgeClass(byte status) => status switch
    {
        2 => "admin-badge-success",
        3 => "admin-badge-muted",
        4 => "admin-badge-danger",
        _ => "admin-badge-warning"
    };

    private static string GetStatusBadgeClass(byte status) => status switch
    {
        2 => "admin-badge-success",
        3 => "admin-badge-muted",
        4 => "admin-badge-danger",
        _ => "admin-badge-warning"
    };
}
