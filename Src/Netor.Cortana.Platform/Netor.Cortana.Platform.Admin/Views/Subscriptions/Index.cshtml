@model Netor.Cortana.Platform.Admin.Models.Subscriptions.SubscriptionIndexViewModel
@using Netor.Cortana.Platform.Entitys.Enums
@{
    ViewData["Title"] = "订阅管理";
}

<section class="metric-grid mb-4">
    <article class="admin-card metric-card">
        <div class="metric-icon">◈</div>
        <strong>@Model.TotalCount</strong>
        <span>订阅总数</span>
        <p>当前筛选范围订阅记录</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">●</div>
        <strong>@Model.ActiveCount</strong>
        <span>有效订阅</span>
        <p>仍在有效期内的权益</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">◌</div>
        <strong>@(Model.ExpiredCount + Model.CanceledCount)</strong>
        <span>失效订阅</span>
        <p>过期或已取消的权益</p>
    </article>
    <article class="admin-card metric-card">
        <div class="metric-icon">↓</div>
        <strong>@Model.DownloadCount</strong>
        <span>下载记录</span>
        <p><a asp-action="Downloads">查看下载明细</a></p>
    </article>
</section>

<section class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title">订阅列表</h2>
        <span class="text-secondary">第 @Model.Page / @Model.TotalPages 页</span>
    </div>
    <div class="admin-card-body border-bottom">
        <form method="get" class="admin-filter-form admin-filter-form-compact layui-form">
            <div>
                <label class="form-label" for="keyword">关键词</label>
                <input id="keyword" class="form-control layui-input" name="keyword" value="@Model.Keyword" placeholder="用户 / 资源 / 方案" />
            </div>
            <div>
                <label class="form-label" for="status">状态</label>
                <select id="status" class="form-select layui-select" name="status">
                    <option value="">全部状态</option>
                    @foreach (var option in Enum.GetValues<SubscriptionStatus>())
                    {
                        <option value="@((int)option)" selected="@(Model.Status == option)">@GetSubscriptionStatusName(option)</option>
                    }
                </select>
            </div>
            <div class="admin-filter-actions">
                <button class="layui-btn layui-btn-normal" type="submit">筛选</button>
                <a class="layui-btn layui-btn-primary" asp-action="Index">重置</a>
            </div>
        </form>
    </div>
    <form id="subscriptionBatchForm" asp-action="Batch" method="post" class="admin-batchbar">
        @Html.AntiForgeryToken()
        <strong>批量操作</strong>
        <div class="admin-batchbar-fields">
            <select class="form-select layui-select" name="operation" aria-label="批量操作">
                <option value="active">批量恢复有效</option>
                <option value="cancel">批量取消</option>
                <option value="expired">批量设为过期</option>
            </select>
            <button class="layui-btn layui-btn-normal" type="submit">应用</button>
        </div>
    </form>
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table layui-table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="admin-check-cell"><input class="form-check-input" type="checkbox" data-check-all="subscriptions" aria-label="全选订阅" /></th>
                        <th>用户</th>
                        <th>资源</th>
                        <th>方案</th>
                        <th>状态</th>
                        <th>有效期</th>
                        <th>下载</th>
                        <th>订单</th>
                        <th class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-secondary py-5">暂无订阅记录。</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="admin-check-cell"><input class="form-check-input" form="subscriptionBatchForm" type="checkbox" name="ids" value="@item.Id" data-check-item="subscriptions" aria-label="选择 @item.AccountName 的订阅" /></td>
                                <td>@item.AccountName</td>
                                <td><strong>@item.AssetName</strong></td>
                                <td>@item.PricingPlanName</td>
                                <td><span class="admin-badge @GetStatusBadgeClass(item.Status)">@item.StatusName</span></td>
                                <td>
                                    <small class="d-block">@item.StartedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</small>
                                    <small class="d-block text-secondary">至 @item.ExpiresAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</small>
                                </td>
                                <td>@item.DownloadCount</td>
                                <td>@(string.IsNullOrWhiteSpace(item.OrderId) ? "-" : item.OrderId)</td>
                                <td class="text-end">
                                    <div class="layui-btn-group admin-row-actions">
                                        @if (item.Status == SubscriptionStatus.Canceled)
                                        {
                                            <form asp-action="Restore" asp-route-id="@item.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button class="layui-btn layui-btn-normal layui-btn-sm" type="submit">恢复</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Cancel" asp-route-id="@item.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button class="layui-btn layui-btn-danger layui-btn-sm" type="submit">取消</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="admin-card-body admin-pager">
        <div class="text-secondary">共 @Model.TotalCount 条，每页 @Model.PageSize 条</div>
        <div class="layui-btn-group">
            <a class="layui-btn layui-btn-primary @(Model.HasPreviousPage ? string.Empty : "layui-btn-disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">上一页</a>
            <a class="layui-btn layui-btn-primary @(Model.HasNextPage ? string.Empty : "layui-btn-disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">下一页</a>
        </div>
    </div>
</section>

@functions {
    private static string GetSubscriptionStatusName(SubscriptionStatus status) => status switch
    {
        SubscriptionStatus.Active => "有效",
        SubscriptionStatus.Expired => "已过期",
        SubscriptionStatus.Canceled => "已取消",
        _ => status.ToString()
    };

    private static string GetStatusBadgeClass(SubscriptionStatus status) => status switch
    {
        SubscriptionStatus.Active => "admin-badge-success",
        SubscriptionStatus.Expired => "admin-badge-warning",
        SubscriptionStatus.Canceled => "admin-badge-danger",
        _ => string.Empty
    };
}
